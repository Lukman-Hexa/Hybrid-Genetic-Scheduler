# ----- Flask -----
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True
FLASK_SECRET_KEY=ganti-dengan-secret-key-acak-yang-kuat

# ----- MongoDB -----
MONGODB_URI=mongodb://localhost:27017/
DATABASE_NAME=scheduling_db

# ----- Auto-Delete Jadwal Lama -----
# Aktifkan/nonaktifkan background scheduler (true/false)
AUTO_DELETE_ENABLED=true

# Hapus jadwal yang lebih tua dari X hari
AUTO_DELETE_DAYS=7

# Jalankan pengecekan setiap X jam (24 = sekali sehari)
AUTO_DELETE_INTERVAL_HOURS=24
